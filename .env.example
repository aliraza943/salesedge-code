# ─── App ──────────────────────────────────────────────────────────────────────
VITE_APP_ID=your_app_id
JWT_SECRET=your_jwt_secret
DATABASE_URL=mysql://user:password@host:3306/dbname

# ─── Manus OAuth ──────────────────────────────────────────────────────────────
OAUTH_SERVER_URL=https://your-oauth-server.com
OWNER_OPEN_ID=your_owner_open_id

# ─── Microsoft Outlook Calendar OAuth ────────────────────────────────────────
# Register an app at https://portal.azure.com → Azure Active Directory → App registrations
# Required API permissions: Calendars.ReadWrite, offline_access, User.Read
# Add redirect URI: https://YOUR_SERVER_DOMAIN/api/outlook/callback
MICROSOFT_CLIENT_ID=your_microsoft_app_client_id
MICROSOFT_CLIENT_SECRET=your_microsoft_app_client_secret
MICROSOFT_TENANT_ID=common
# Use "common" for multi-tenant (personal + work accounts)
# Use your tenant ID for single-tenant (work accounts only)
